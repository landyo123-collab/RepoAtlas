# Copy this file to ~/.repoatlas.env and paste your keys.

# DeepSeek (reasoning / Q&A / run planning)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (embeddings only — improves retrieval quality)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDINGS_ENABLED=true

# OpenAI Evidence Builder (multi-pass implementation evidence for DeepSeek)
# Uses the same OPENAI_API_KEY above. Enable to get richer repo context.
OPENAI_EVIDENCE_BUILDER_ENABLED=false
OPENAI_EVIDENCE_BUILDER_MODEL=gpt-4.1-mini
OPENAI_EVIDENCE_BUILDER_MAX_PASSES=3
OPENAI_EVIDENCE_BUILDER_MAX_CANDIDATES=1500
OPENAI_EVIDENCE_BUILDER_MAX_BATCHES=12
OPENAI_EVIDENCE_BUILDER_MAX_DOSSIER_TOKENS=24000
